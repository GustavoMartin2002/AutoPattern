# Security Settings
ALLOWED_ORIGINS=http://localhost:3000, http://localhost:8080
MAX_FILE_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=10
ENABLE_HSTS=false

# Logging
SECURITY_LOG_FILE=logs/security.log
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development

# Server
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_RELOAD=true